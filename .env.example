# gChat Network Environment Configuration
# Copy this file to .env and customize for your local development or deployment needs.

# -----------------------------------------------------
# Node Identity & Topology
# -----------------------------------------------------
# Determines the behavior of this node on the network.
# Valid Options: 
#   - MASTER (Runs Tor, handles mesh routing & gossip, headless)
#   - SLAVE_STORAGE (Headless localized database API)
#   - SLAVE_FRONTEND (UI only, connects to MASTER over LAN)
#   - MICRO_SITE (Static marketing and Tor download gateway)
NODE_ROLE=MASTER

# The IP Address of the MASTER node on your LAN. 
# Slaves use this to connect to the Master's private Socket.io API.
MASTER_IP=127.0.0.1

# The same IP address exposed to the Vite React frontend.
# Must match MASTER_IP for SLAVE_FRONTEND nodes.
VITE_MASTER_IP=127.0.0.1

# The ports exposed to the Vite React frontend.
VITE_API_PORT=3001
VITE_FRONTEND_PORT=3000

# The role exposed to the Vite React frontend (used for frontend-only mode detection).
VITE_NODE_ROLE=MASTER

# Set to 'true' to force the UI to render even on headless roles (like MASTER).
# This is automatically 'true' for SLAVE_FRONTEND.
FORCE_UI=false

# -----------------------------------------------------
# Port Bindings
# -----------------------------------------------------
# The port the Node.js backend (Socket.io & Express) will listen on.
API_PORT=3001

# The port the Vite React frontend development server will listen on.
FRONTEND_PORT=3000

# -----------------------------------------------------
# Storage & Paths
# -----------------------------------------------------
# Overrides the default storage location for SQLite databases and Media files.
# Default is usually ~/.local/share/gchat on Linux.
# APP_DATA_ROOT=/custom/path/to/storage

# -----------------------------------------------------
# Deployer Configuration (scripts/deploy.js)
# -----------------------------------------------------
# Custom Git parameters used by the automated SSH deployer to provision remote Slave nodes.
GIT_REPO_URL=https://github.com/DeveLooped-INC/gChat.git
GIT_BRANCH=main
